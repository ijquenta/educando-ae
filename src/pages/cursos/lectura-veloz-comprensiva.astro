---
import Base from "@/layouts/Base.astro";
---

<Base entry_keys={["pages", "index"]}>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center overflow-hidden py-16">
    <div class="absolute inset-0 opacity-20 pointer-events-none">
      <div class="w-full h-full bg-[url('https://www.transparenttextures.com/patterns/paper-fibers.png')] dark:bg-[url('https://www.transparenttextures.com/patterns/dark-mosaic.png')]"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
        
        <!-- Content Section -->
        <div class="motion-preset-slide-right motion-on-scroll">
          <a href="/cursos" data-back="true" aria-label="Volver" class="inline-flex items-center gap-2 text-sm font-medium text-secondary bg-white/90 dark:bg-gray-800 px-3 py-1 rounded-full shadow hover:scale-105 transition-transform mb-4">
            <span class="text-lg">←</span>
            <span class="hidden sm:inline">Volver</span>
          </a>
          <h1 class="text-4xl md:text-5xl font-extrabold text-secondary mb-4">
            Lectura Veloz y Comprensiva
          </h1>
          <p class="text-gray-700 dark:text-gray-200 text-lg mb-8">
            Domina la técnica de lectura ultraveloz con comprensión crítica. Alcanza velocidades de 1,000+ palabras por minuto manteniendo excelente retención.
          </p>

          <div class="bg-white dark:bg-gray-800 rounded-2xl p-8 shadow-lg mb-8">
            <h2 class="text-2xl font-bold text-secondary mb-4">Información del Curso</h2>
            
            <div class="space-y-4 mb-6">
              <div class="flex items-start gap-3">
                <div>
                  <p class="font-semibold text-gray-800 dark:text-white">Duración</p>
                  <p class="text-gray-700 dark:text-gray-300">2 a 5 meses</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div>
                  <p class="font-semibold text-gray-800 dark:text-white">Público Objetivo</p>
                  <p class="text-gray-700 dark:text-gray-300">Estudiantes avanzados</p>
                </div>
              </div>
            </div>

            <a
              href="https://wa.me/59178792865?text=Hola%20Educando%2C%20quiero%20inscribirme%20al%20curso%20de%20Lectura%20Veloz%20y%20Comprensiva.%20Quisiera%20m%C3%A1s%20informaci%C3%B3n%20por%20favor."
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Inscribirse por WhatsApp"
              class="w-full inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:scale-105"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                <path d="M20.52 3.48A11.93 11.93 0 0012 0C5.373 0 .001 5.373.001 12c0 2.113.55 4.18 1.596 6.02L0 24l6.206-1.592A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12 0-3.207-1.252-6.216-3.48-8.52zM12 21.6c-1.66 0-3.27-.45-4.66-1.3l-.33-.2-3.68.94.98-3.59-.21-.36A9.6 9.6 0 012.4 12 9.6 9.6 0 0112 2.4 9.6 9.6 0 0121.6 12 9.6 9.6 0 0112 21.6z"/>
                <path d="M17.14 14.9c-.29-.15-1.71-.84-1.98-.94-.26-.1-.45-.15-.64.15-.19.29-.74.94-.9 1.13-.16.19-.31.21-.58.07-.27-.15-1.14-.42-2.17-1.33-.8-.71-1.34-1.59-1.5-1.86-.16-.27-.02-.42.12-.56.12-.12.27-.31.4-.46.13-.15.17-.27.26-.45.09-.19.04-.36-.02-.51-.07-.15-.64-1.54-.88-2.11-.23-.55-.46-.48-.64-.49l-.55-.01c-.19 0-.5.07-.77.36-.27.29-1.03 1.01-1.03 2.46 0 1.45 1.05 2.86 1.2 3.06.15.2 2.08 3.18 5.04 4.33 2.96 1.16 2.96.77 3.5.72.54-.05 1.75-.72 2-1.42.25-.7.25-1.3.18-1.42-.07-.12-.26-.19-.55-.34z"/>
              </svg>
              <span>Inscribirse</span>
            </a>
          </div>
        </div>

        <!-- Image Section -->
        <div class="motion-scale-in-[0.5] motion-delay-[0.4s] motion-on-scroll">
          <div class="relative w-full h-96 rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/images/curso-lectura-rapida.jpg" 
              alt="Lectura Veloz y Comprensiva" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-br from-secondary/20 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Content Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-12 text-center">
        Fases del Programa
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">1</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Diagnóstico Inicial</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Evaluación de velocidad actual</li>
            <li>Medición de comprensión</li>
            <li>Identificación de hábitos</li>
            <li>Diseño de plan personalizado</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">2</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Técnicas Neurometal</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Activación de potencial cerebral</li>
            <li>Sincronización hemisférica</li>
            <li>Ampliación del campo visual</li>
            <li>Procesamiento acelerado</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">3</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Comprensión Crítica</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Lectura analítica</li>
            <li>Identificación de patrones</li>
            <li>Pensamiento crítico</li>
            <li>Síntesis de información</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">4</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Retención Avanzada</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Técnicas de memoria</li>
            <li>Mapeo mental</li>
            <li>Resumen efectivo</li>
            <li>Recordar a largo plazo</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">5</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Velocidades Progresivas</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Entrenamiento gradual</li>
            <li>Aumento escalonado</li>
            <li>Adaptación cognitiva</li>
            <li>Consolidación de habilidades</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-2xl font-bold text-secondary">6</span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">Maestría Final</h3>
          </div>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Lectura a 1,000+ palabras/minuto</li>
            <li>Comprensión del 95%+</li>
            <li>Aplicación profesional</li>
            <li>Certificación de competencia</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Results Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-12 text-center">
        Resultados Garantizados
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-4xl font-bold text-secondary mb-2">10x</div>
          <p class="text-gray-700 dark:text-gray-300 font-semibold">
            Incremento de velocidad
          </p>
        </div>

        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-4xl font-bold text-secondary mb-2">95%</div>
          <p class="text-gray-700 dark:text-gray-300 font-semibold">
            Comprensión garantizada
          </p>
        </div>

        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-4xl font-bold text-secondary mb-2">80%</div>
          <p class="text-gray-700 dark:text-gray-300 font-semibold">
            Ahorro de tiempo
          </p>
        </div>

        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-4xl font-bold text-secondary mb-2">100%</div>
          <p class="text-gray-700 dark:text-gray-300 font-semibold">
            Satisfacción comprobada
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-br from-secondary/10 to-transparent">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-6">
        Una Llave para el Éxito del Mañana
      </h2>
      <p class="text-gray-700 dark:text-gray-200 text-lg mb-8 max-w-2xl mx-auto">
        Únete a cientos de profesionales que han transformado su forma de leer y aprender. Lectura ultraveloz con máxima comprensión.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a
          href="https://wa.me/59178792865?text=Hola%20Educando%2C%20quiero%20inscribirme%20al%20curso%20de%20Lectura%20Veloz%20y%20Comprensiva.%20Quisiera%20m%C3%A1s%20informaci%C3%B3n%20por%20favor."
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Inscribirse por WhatsApp"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 px-8 rounded-lg transition-all duration-300 hover:scale-105"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M20.52 3.48A11.93 11.93 0 0012 0C5.373 0 .001 5.373.001 12c0 2.113.55 4.18 1.596 6.02L0 24l6.206-1.592A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12 0-3.207-1.252-6.216-3.48-8.52zM12 21.6c-1.66 0-3.27-.45-4.66-1.3l-.33-.2-3.68.94.98-3.59-.21-.36A9.6 9.6 0 012.4 12 9.6 9.6 0 0112 2.4 9.6 9.6 0 0121.6 12 9.6 9.6 0 0112 21.6z"/>
            <path d="M17.14 14.9c-.29-.15-1.71-.84-1.98-.94-.26-.1-.45-.15-.64.15-.19.29-.74.94-.9 1.13-.16.19-.31.21-.58.07-.27-.15-1.14-.42-2.17-1.33-.8-.71-1.34-1.59-1.5-1.86-.16-.27-.02-.42.12-.56.12-.12.27-.31.4-.46.13-.15.17-.27.26-.45.09-.19.04-.36-.02-.51-.07-.15-.64-1.54-.88-2.11-.23-.55-.46-.48-.64-.49l-.55-.01c-.19 0-.5.07-.77.36-.27.29-1.03 1.01-1.03 2.46 0 1.45 1.05 2.86 1.2 3.06.15.2 2.08 3.18 5.04 4.33 2.96 1.16 2.96.77 3.5.72.54-.05 1.75-.72 2-1.42.25-.7.25-1.3.18-1.42-.07-.12-.26-.19-.55-.34z"/>
          </svg>
          <span>Inscribirse</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Intersection Observer Script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Marcar todos como activos inicialmente para evitar invisibilidad en carga
      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        el.classList.add('motion-active');
      });

      // Luego configurar el observer para animaciones al scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('motion-active');
          }
        });
      }, { threshold: 0.05 });

      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        observer.observe(el);
      });

      // Back buttons: attach listener to elements with data-back to avoid inline event usage
      document.querySelectorAll('[data-back="true"]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          if (history.length > 1) history.back();
          else location.href = '/cursos';
        });
      });
    });
  </script>

  <style>
    .motion-on-scroll {
      will-change: opacity, transform;
    }
  </style>
</Base>
