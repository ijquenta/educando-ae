          <div class="relative w-full h-96 rounded-2xl overflow-hidden shadow-2xl">
            <img 
              src="/images/curso-lectura-rapida.jpg" 
              alt="Lectura Rápida" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-br from-secondary/20 to-transparent"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Content Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-12 text-center">
        ¿Qué Aprenderás?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <h3 class="text-xl font-semibold text-secondary mb-3">Técnicas de Lectura Acelerada</h3>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Expansión del campo visual</li>
            <li>Eliminación de regresiones</li>
            <li>Técnicas de skimming</li>
            <li>Lectura de palabras claves</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <h3 class="text-xl font-semibold text-secondary mb-3">Mejora de Comprensión</h3>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Activación del conocimiento previo</li>
            <li>Análisis de estructura de textos</li>
            <li>Identificación de ideas principales</li>
            <li>Síntesis y retención de información</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <h3 class="text-xl font-semibold text-secondary mb-3">Desarrollo de Habilidades</h3>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Entrenamiento visual</li>
            <li>Concentración mejorada</li>
            <li>Memoria efectiva</li>
            <li>Gestión del tiempo de lectura</li>
          </ul>
        </div>

        <div class="p-6 rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <h3 class="text-xl font-semibold text-secondary mb-3">Práctica Continua</h3>
          <ul class="text-gray-700 dark:text-gray-300 space-y-2 list-disc list-inside">
            <li>Ejercicios progresivos</li>
            <li>Evaluaciones semanales</li>
            <li>Materiales de diferentes géneros</li>
            <li>Retroalimentación personalizada</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-12 text-center">
        Beneficios del Curso
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-5xl font-bold text-secondary mb-3">3x</div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-2">Más Rápido</h3>
          <p class="text-gray-700 dark:text-gray-300">
            Aumenta tu velocidad lectora hasta 3 veces más rápido que el promedio.
          </p>
        </div>

        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-5xl font-bold text-secondary mb-3">95%</div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-2">Comprensión</h3>
          <p class="text-gray-700 dark:text-gray-300">
            Mantén excelente comprensión mientras lees más rápido.
          </p>
        </div>

        <div class="p-6 text-center rounded-lg bg-white dark:bg-gray-800 shadow-md hover:shadow-lg transition-all duration-300">
          <div class="text-5xl font-bold text-secondary mb-3">+50%</div>
          <h3 class="text-xl font-semibold text-gray-800 dark:text-white mb-2">Retención</h3>
          <p class="text-gray-700 dark:text-gray-300">
            Mejora tu capacidad de retención de información.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-br from-secondary/10 to-transparent">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-secondary mb-6">
        ¿Listo para Transformar tu Lectura?
      </h2>
      <p class="text-gray-700 dark:text-gray-200 text-lg mb-8 max-w-2xl mx-auto">
        Únete a cientos de estudiantes que ya han mejorado sus habilidades de lectura y están logrando mejores resultados académicos.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="https://wa.me/59178792865?text=Hola%20Educando%2C%20quiero%20inscribirme%20al%20curso%20de%20Lectura%20Rápida.%20Quisiera%20m%C3%A1s%20informaci%C3%B3n%20por%20favor." target="_blank" rel="noopener noreferrer" aria-label="Inscribirse por WhatsApp" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 px-8 rounded-lg transition-all duration-300 hover:scale-105">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M20.52 3.48A11.93 11.93 0 0012 0C5.373 0 .001 5.373.001 12c0 2.113.55 4.18 1.596 6.02L0 24l6.206-1.592A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12 0-3.207-1.252-6.216-3.48-8.52zM12 21.6c-1.66 0-3.27-.45-4.66-1.3l-.33-.2-3.68.94.98-3.59-.21-.36A9.6 9.6 0 012.4 12 9.6 9.6 0 0112 2.4 9.6 9.6 0 0121.6 12 9.6 9.6 0 0112 21.6z"/>
            <path d="M17.14 14.9c-.29-.15-1.71-.84-1.98-.94-.26-.1-.45-.15-.64.15-.19.29-.74.94-.9 1.13-.16.19-.31.21-.58.07-.27-.15-1.14-.42-2.17-1.33-.8-.71-1.34-1.59-1.5-1.86-.16-.27-.02-.42.12-.56.12-.12.27-.31.4-.46.13-.15.17-.27.26-.45.09-.19.04-.36-.02-.51-.07-.15-.64-1.54-.88-2.11-.23-.55-.46-.48-.64-.49l-.55-.01c-.19 0-.5.07-.77.36-.27.29-1.03 1.01-1.03 2.46 0 1.45 1.05 2.86 1.2 3.06.15.2 2.08 3.18 5.04 4.33 2.96 1.16 2.96.77 3.5.72.54-.05 1.75-.72 2-1.42.25-.7.25-1.3.18-1.42-.07-.12-.26-.19-.55-.34z"/>
          </svg>
          <span>Inscribirse</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Intersection Observer Script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Marcar todos como activos inicialmente para evitar invisibilidad en carga
      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        el.classList.add('motion-active');
      });

      // Luego configurar el observer para animaciones al scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('motion-active');
          }
        });
      }, { threshold: 0.05 });

      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        observer.observe(el);
      });

      // Back buttons: attach listener to elements with data-back to avoid inline event usage
      document.querySelectorAll('[data-back="true"]').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          if (history.length > 1) history.back();
          else location.href = '/cursos';
        });
      });
    });
  </script>

  <style>
    .motion-on-scroll {
      will-change: opacity, transform;
    }
  </style>
</Base>
