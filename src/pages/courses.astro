---
import Base from "@/layouts/Base.astro";
import ImageCarousel from "@/components/react/ImageCarousel";
---

<Base entry_keys={["pages", "index"]}>
  <!-- Hero Section Enhanced -->
  <section class="relative min-h-screen flex items-center overflow-hidden py-16">
    <!-- Carousel Background -->
    <div class="absolute inset-0 z-0">
      <ImageCarousel client:load />
    </div>
    
    <!-- Overlay to darken carousel -->
    <div class="absolute inset-0 bg-black/50 dark:bg-black/60 z-5"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl">
        <div class="mb-8 motion-preset-fade motion-on-scroll">
          <span class="inline-block bg-secondary/10 dark:bg-secondary/20 text-secondary font-semibold px-4 py-2 rounded-full text-sm mb-6">
            🎓 Programas Educativos de Alto Impacto
          </span>
        </div>
        <h1 class="text-6xl md:text-7xl font-extrabold text-white mb-6 motion-preset-fade motion-translate-y-in-[25%] motion-on-scroll leading-tight">
          Nuestros <span class="bg-gradient-to-r from-secondary to-secondary/70 bg-clip-text text-transparent">Cursos</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-100 mb-6 motion-preset-fade motion-delay-[0.2s] motion-on-scroll max-w-2xl">
          Programas especializados diseñados para transformar tu educación y desarrollar habilidades estratégicas para tu futuro.
        </p>
        <p class="text-lg text-gray-200 motion-preset-fade motion-delay-[0.4s] motion-on-scroll max-w-2xl leading-relaxed">
          Metodologías comprobadas, mentorería personalizada y comunidad de aprendices que comparten tu visión de crecimiento.
        </p>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 bg-gradient-to-r from-secondary/5 to-transparent dark:from-secondary/10 dark:to-transparent border-b border-gray-200 dark:border-gray-800">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center motion-preset-fade motion-on-scroll">
          <div class="text-3xl md:text-4xl font-bold text-secondary mb-2">500+</div>
          <p class="text-gray-700 dark:text-gray-300 text-sm">Estudiantes Activos</p>
        </div>
        <div class="text-center motion-preset-fade motion-delay-[0.1s] motion-on-scroll">
          <div class="text-3xl md:text-4xl font-bold text-secondary mb-2">4</div>
          <p class="text-gray-700 dark:text-gray-300 text-sm">Especialidades</p>
        </div>
        <div class="text-center motion-preset-fade motion-delay-[0.2s] motion-on-scroll">
          <div class="text-3xl md:text-4xl font-bold text-secondary mb-2">95%</div>
          <p class="text-gray-700 dark:text-gray-300 text-sm">Satisfacción</p>
        </div>
        <div class="text-center motion-preset-fade motion-delay-[0.3s] motion-on-scroll">
          <div class="text-3xl md:text-4xl font-bold text-secondary mb-2">6+</div>
          <p class="text-gray-700 dark:text-gray-300 text-sm">Años Experiencia</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cursos Grid Section -->
  <section class="py-24">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 motion-preset-fade motion-on-scroll">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
          Especializaciones Disponibles
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Elige tu camino de aprendizaje. Cada curso es una oportunidad para transformar tus habilidades y alcanzar tus metas.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
        
        <!-- Curso 1: Lectura Rápida para Niños y Jóvenes -->
        <a href="/cursos/lectura-rapida" class="group relative overflow-hidden rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-105 motion-preset-bounce motion-on-scroll block bg-white dark:bg-gray-800">
          <div class="relative h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
            <img 
              src="/images/curso-lectura-rapida.jpg" 
              alt="Lectura Rápida para Niños y Jóvenes" 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/20 to-transparent opacity-70 group-hover:opacity-50 transition-all duration-300"></div>
            
          </div>
          <div class="p-8">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
                  Lectura Rápida
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Lectura & Comprensión</p>
              </div>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-6 line-clamp-2">
              Aprende técnicas comprobadas para leer más rápido sin perder comprensión. Ideal para estudiantes de 8 a 18 años.
            </p>
          </div>
        </a>

        <!-- Curso 2: Matemáticas -->
        <a href="/cursos/matematicas" class="group relative overflow-hidden rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-105 motion-scale-in-[0.5] motion-rotate-in-[-10deg] motion-on-scroll block bg-white dark:bg-gray-800">
          <div class="relative h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
            <img 
              src="/images/curso-mate.jpg" 
              alt="Matemáticas" 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/20 to-transparent opacity-70 group-hover:opacity-50 transition-all duration-300"></div>
            
          </div>
          <div class="p-8">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
                  Matemáticas
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Conceptos Fundamentales</p>
              </div>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-6 line-clamp-2">
              Domina conceptos matemáticos con un enfoque práctico, desde lo básico hasta lo avanzado con aplicaciones reales.
            </p>
          </div>
        </a>

        <!-- Curso 3: Desarrollo de Videojuegos -->
        <a href="/cursos/desarrollo-videojuegos" class="group relative overflow-hidden rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-105 motion-preset-pop motion-on-scroll block bg-white dark:bg-gray-800">
          <div class="relative h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
            <img 
              src="/images/curso-videojuegos.jpg" 
              alt="Desarrollo de Videojuegos" 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/20 to-transparent opacity-70 group-hover:opacity-50 transition-all duration-300"></div>
            
          </div>
          <div class="p-8">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
                  Desarrollo de Videojuegos
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Programación Creativa</p>
              </div>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-6 line-clamp-2">
              Crea videojuegos profesionales con Unity, Unreal Engine y Godot. De cero a portafolio profesional.
            </p>
          </div>
        </a>

        <!-- Curso 4: Lectura Veloz y Comprensiva -->
        <a href="/cursos/lectura-veloz-comprensiva" class="group relative overflow-hidden rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-300 hover:scale-105 motion-translate-x-in-[-25%] motion-translate-y-in-[25%] motion-on-scroll block bg-white dark:bg-gray-800">
          <div class="relative h-80 overflow-hidden bg-gray-200 dark:bg-gray-700">
            <img 
              src="/images/curso-lectura-rapida.jpg" 
              alt="Lectura Veloz y Comprensiva" 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/20 to-transparent opacity-70 group-hover:opacity-50 transition-all duration-300"></div>
          </div>
          <div class="p-8">
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-secondary transition-colors">
                  Lectura Veloz y Comprensiva
                </h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Nivel Experto</p>
              </div>
            </div>
            <p class="text-gray-700 dark:text-gray-300 mb-6 line-clamp-2">
              Alcanza 1,000+ palabras por minuto con comprensión crítica. Para estudiantes avanzados y profesionales.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Enhanced CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-secondary/10 to-transparent dark:from-secondary/5"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-secondary/10 rounded-full blur-3xl -z-10"></div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center motion-preset-fade motion-on-scroll">
        <h2 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
          Inicia Tu Transformación Hoy
        </h2>
        <p class="text-xl md:text-2xl text-gray-700 dark:text-gray-300 mb-4">
          Únete a cientos de estudiantes que ya están transformando sus vidas
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center motion-preset-bounce motion-delay-[0.2s] motion-on-scroll">
          <a
            href="https://wa.me/59178792865?text=Hola%20Educando%2C%20quiero%20inscribirme%20a%20un%20curso.%20Quisiera%20m%C3%A1s%20informaci%C3%B3n%20por%20favor."
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Inscribirse por WhatsApp"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-secondary hover:bg-secondary/90 text-white font-semibold py-3 px-6 rounded-lg transition-all duration-300 hover:scale-105"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M20.52 3.48A11.93 11.93 0 0012 0C5.373 0 .001 5.373.001 12c0 2.113.55 4.18 1.596 6.02L0 24l6.206-1.592A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12 0-3.207-1.252-6.216-3.48-8.52zM12 21.6c-1.66 0-3.27-.45-4.66-1.3l-.33-.2-3.68.94.98-3.59-.21-.36A9.6 9.6 0 012.4 12 9.6 9.6 0 0112 2.4 9.6 9.6 0 0121.6 12 9.6 9.6 0 0112 21.6z"/>
              <path d="M17.14 14.9c-.29-.15-1.71-.84-1.98-.94-.26-.1-.45-.15-.64.15-.19.29-.74.94-.9 1.13-.16.19-.31.21-.58.07-.27-.15-1.14-.42-2.17-1.33-.8-.71-1.34-1.59-1.5-1.86-.16-.27-.02-.42.12-.56.12-.12.27-.31.4-.46.13-.15.17-.27.26-.45.09-.19.04-.36-.02-.51-.07-.15-.64-1.54-.88-2.11-.23-.55-.46-.48-.64-.49l-.55-.01c-.19 0-.5.07-.77.36-.27.29-1.03 1.01-1.03 2.46 0 1.45 1.05 2.86 1.2 3.06.15.2 2.08 3.18 5.04 4.33 2.96 1.16 2.96.77 3.5.72.54-.05 1.75-.72 2-1.42.25-.7.25-1.3.18-1.42-.07-.12-.26-.19-.55-.34z"/>
            </svg>
            <span>Inscribirse</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section Enhanced -->
  <section class="py-24 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-200 dark:border-gray-800">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 motion-preset-fade motion-on-scroll">
        <h2 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
          Preguntas Frecuentes
        </h2>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Resolvemos tus dudas sobre nuestros cursos y proceso de inscripción
        </p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          <details class="group p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300 motion-preset-fade motion-on-scroll open:bg-blue-50 dark:open:bg-blue-900/20 open:border-l-4 open:border-l-secondary">
            <summary class="flex items-center justify-between cursor-pointer select-none">
              <span class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white">
                ¿Puedo combinar varios cursos?
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-2xl">▼</span>
            </summary>
            <p class="text-gray-700 dark:text-gray-300 mt-4 leading-relaxed">
              Sí, nuestros cursos están diseñados para complementarse. Puedes comenzar con uno y agregar otros según tu disponibilidad y objetivos. Ofrecemos paquetes especiales cuando cursas más de uno.
            </p>
          </details>

          <details class="group p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300 motion-preset-fade motion-delay-[0.1s] motion-on-scroll open:bg-blue-50 dark:open:bg-blue-900/20 open:border-l-4 open:border-l-secondary">
            <summary class="flex items-center justify-between cursor-pointer select-none">
              <span class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white">
                ¿Hay descuentos para grupos o instituciones?
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-2xl">▼</span>
            </summary>
            <p class="text-gray-700 dark:text-gray-300 mt-4 leading-relaxed">
              Absolutamente. Contáctanos directamente para consultar sobre programas especiales para grupos, escuelas e instituciones educativas. Tenemos planes personalizados y descuentos para matriculas múltiples.
            </p>
          </details>

          <details class="group p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300 motion-preset-fade motion-delay-[0.2s] motion-on-scroll open:bg-blue-50 dark:open:bg-blue-900/20 open:border-l-4 open:border-l-secondary">
            <summary class="flex items-center justify-between cursor-pointer select-none">
              <span class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white">
                ¿Recibo certificado al finalizar?
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-2xl">▼</span>
            </summary>
            <p class="text-gray-700 dark:text-gray-300 mt-4 leading-relaxed">
              Sí. Al completar cada curso, recibirás un certificado oficial de Educando AE que reconoce tu logro y competencias adquiridas. Este certificado es válido internacionalmente y puedes compartirlo en redes profesionales.
            </p>
          </details>

          <details class="group p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300 motion-preset-fade motion-delay-[0.3s] motion-on-scroll open:bg-blue-50 dark:open:bg-blue-900/20 open:border-l-4 open:border-l-secondary">
            <summary class="flex items-center justify-between cursor-pointer select-none">
              <span class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white">
                ¿Cómo es el proceso de inscripción?
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-2xl">▼</span>
            </summary>
            <p class="text-gray-700 dark:text-gray-300 mt-4 leading-relaxed">
              Es simple: 1) Selecciona tu curso, 2) Completa el formulario de inscripción, 3) Realiza el pago y 4) Recibirás acceso inmediato al material del curso. Nuestro equipo te contactará en 24 horas para personalizar tu experiencia.
            </p>
          </details>

          <details class="group p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg transition-all duration-300 motion-preset-fade motion-delay-[0.4s] motion-on-scroll open:bg-blue-50 dark:open:bg-blue-900/20 open:border-l-4 open:border-l-secondary">
            <summary class="flex items-center justify-between cursor-pointer select-none">
              <span class="text-lg md:text-xl font-semibold text-gray-900 dark:text-white">
                ¿Hay garantía de satisfacción?
              </span>
              <span class="transition-transform duration-300 group-open:rotate-180 text-2xl">▼</span>
            </summary>
            <p class="text-gray-700 dark:text-gray-300 mt-4 leading-relaxed">
              Tenemos una política de 14 días de garantía de satisfacción. Si no estás conforme con el curso en el primer mes, ofrecemos un reembolso completo. Tu éxito es nuestra prioridad.
            </p>
          </details>
        </div>

      </div>
    </div>
  </section>

  <!-- Intersection Observer Script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      // Marcar todos como activos inicialmente para evitar invisibilidad en carga
      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        el.classList.add('motion-active');
      });

      // Luego configurar el observer para animaciones al scroll
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('motion-active');
          }
        });
      }, { threshold: 0.05 });

      document.querySelectorAll('.motion-on-scroll').forEach(el => {
        observer.observe(el);
      });
    });
  </script>

  <style>
    .motion-on-scroll {
      will-change: opacity, transform;
    }
  </style>
</Base>
